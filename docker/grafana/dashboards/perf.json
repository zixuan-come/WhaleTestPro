{
  "uid": "perf-dash",
  "title": "WhaleTestPro 压测监控",
  "tags": ["whaletestpro"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "请求速率 sum(rate(http_requests_total[1m])) by (handler)",
      "datasource": { "type": "prometheus", "uid": "prom1" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "reqps" },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prom1" },
          "expr": "sum(rate(http_requests_total[1m])) by (handler)",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "P95 响应时间 histogram_quantile(0.95) by (handler)",
      "datasource": { "type": "prometheus", "uid": "prom1" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 9 },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "s" },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prom1" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[1m])) by (le, handler))",
          "legendFormat": "{{handler}}"
        }
      ]
    }
  ]
}
